{
  "name": "onenote-integration",
  "version": "1.3.4",
  "description": "Embed and edit OneNote notes in Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build:test": "npm run build && node -e \"const fs=require('fs'),d='../test-vault/.obsidian/plugins/onenote-integration';fs.mkdirSync(d,{recursive:true});['main.js','manifest.json','styles.css','onenote-repos.exe','win-embed-overlay.exe'].forEach(f=>{try{fs.copyFileSync(f,d+'/'+f)}catch(e){console.warn('skip:',f)}})\"",
    "watch": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile:exe": "compile-repos.bat"
  },
  "keywords": [
    "obsidian",
    "onenote",
    "plugin"
  ],
  "author": "Qoder",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.0",
    "esbuild-plugin-copy": "^2.1.0",
    "jsdom": "^29.1.1",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  }
}
